# Dockerfile para desarrollo local con hot-reload
# Usado por docker-compose en modo desarrollo

FROM node:20-alpine

RUN apk add --no-cache libc6-compat

WORKDIR /app

# Instalar deps en build time; el volumen anónimo /app/node_modules los preserva entre reinicios.
# Si package.json cambia: docker-compose run frontend yarn install
COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile

EXPOSE 3000

CMD ["yarn", "dev"]
